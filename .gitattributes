# Normalize line endings — the repo stores LF so Windows dev and the Linux
# (Cloudflare Pages) build environment stay byte-identical.
* text=auto eol=lf

# Windows-only scripts must keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — never convert or diff
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   text
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.xlsx  binary
*.xls   binary

# Generated lockfiles — collapse in diffs / reviews
package-lock.json -diff linguist-generated
