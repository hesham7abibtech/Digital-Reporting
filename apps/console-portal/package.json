{
  "name": "@reh/console-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" next dev --port 3001",
    "build": "node scripts/generate-version.mjs && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" next build",
    "start": "next start --port 3001",
    "lint": "eslint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "deploy": "npx wrangler pages deploy .vercel/output/static --project-name rehdigital-console",
    "pages:deploy": "npm run pages:build && npm run deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@openai/agents": "^0.11.4",
    "@reh/shared": "*",
    "@supabase/supabase-js": "^2.108.2",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@types/nodemailer": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "nodemailer": "^8.0.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-easy-crop": "^5.5.7",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/postcss": "^4",
    "cross-env": "^7.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.19.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^3.107.2"
  }
