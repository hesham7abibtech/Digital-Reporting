rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- SECURITY HELPERS ---
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      // 1. High-Speed Clearance (Zero Lookups)
      // 2. Standard Clearance (Database-Driven)
      return isAuth() && (
        request.auth.token.email.lower() in [
          'hesham.7abib@modon.com'.lower(),
          'hesham.habib@insiteinternational.com'.lower()
        ] || 
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['ADMIN', 'OWNER', 'SUPER_ADMIN']
          )
        )
      );
    }

    function isApproved() {
      return isAuth() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isApproved', false) == true;
    }

    // Public Project Identity
    match /settings/project { allow read: if true; }
    match /settings/homePage { allow read: if true; }

    // Protected Settings (admin write, approved read)
    match /settings/{docId} {
      allow read: if isAuth() && (isApproved() || isAdmin());
      allow write: if isAdmin();
    }

    // Diagnostic Audit Logs
    match /diagnostics/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // Users Registry
    match /users/{userId} {
      allow create: if isAuth() && request.auth.uid == userId;
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin() || isApproved());
      allow update: if isAuth() && (
        isAdmin() ||
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isApproved', 'access', 'email', 'role']))
      );
      allow delete: if isAdmin();
    }

    // Members / Team Listing
    match /members/{memberId} {
      allow read: if isAuth() && (isApproved() || isAdmin());
      allow write: if isAdmin();
    }

    // Registry / Nav Items
    match /registry/{itemId} {
      allow read: if isAuth() && (isApproved() || isAdmin());
      allow write: if isAdmin();
    }

    // Departments
    match /departments/{deptId} {
      allow read: if isAuth() && (isApproved() || isAdmin());
      allow write: if isAdmin();
    }

    // Tasks / Deliverables
    match /tasks/{taskId} {
      allow read: if isAdmin() || (isApproved() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('access', {}).get('deliverablesRegistry', false) == true);
      allow write: if isAdmin();
    }

    // BIM Reviews
    match /bimReviews/{reviewId} {
      allow read: if isAdmin() || (isApproved() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('access', {}).get('bimReviews', false) == true);
      allow write: if isAdmin();
    }

    // Group Policies
    match /policies/{policyId} {
      allow read, write: if isAdmin();
    }

    // Project Metadata
    match /projectMetadata/{docId} {
      allow read: if isAuth() && (isApproved() || isAdmin());
      allow write: if isAdmin();
    }

    // Broadcasts / News
    match /broadcasts/{docId} {
      allow read: if isAuth() && (isApproved() || isAdmin());
      allow create, delete: if isAdmin();
      allow update: if isAuth() && (
        isAdmin() || 
        (isApproved() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']))
      );
    }

    // Global Fallback (Admin-only catch-all)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
