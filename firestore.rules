rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helpers ─────────────────────────────────────────────────────
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user has an Admin or Owner role
    function isAdmin() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && 
             exists(userDoc) &&
             (get(userDoc).data.role in ['ADMIN', 'OWNER']);
    }

    // Check if the user is a superuser (Owner)
    function isOwnerRole() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && 
             exists(userDoc) &&
             get(userDoc).data.role == 'OWNER';
    }

    // Check granular admin permissions based on Dynamic Group Policy
    function hasPermission(module, action) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.role == 'OWNER' || (
        userData.role == 'ADMIN' && 
        userData.policyId != null && 
        get(/databases/$(database)/documents/policies/$(userData.policyId)).data.modules[module][action] == true
      );
    }

    
    // Check if the user is accessing their own document
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ─── User Profiles ───────────────────────────────────────────────
    
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'TEAM_MATE';
      
      allow update: if isOwnerRole() 
                    || (hasPermission('users', 'edit') && resource.data.role != 'OWNER')
                    || (isOwner(uid) && request.resource.data.role == resource.data.role);
      
      allow delete: if isOwnerRole() || hasPermission('users', 'delete');
    }

    // ─── Group Policies ──────────────────────────────────────────────
    
    match /policies/{policyId} {
      allow read: if isAdmin();
      allow write: if isOwnerRole(); // Only Owners can forge policies
    }

    // ─── Project Data (Tasks, Members, Registry) ─────────────────────
    
    match /tasks/{taskId} {
      allow read: if true;
      allow create, update: if hasPermission('tasks', 'edit') 
                    || (isAuthenticated() && request.auth.uid == resource.data.assigneeId);
      allow delete: if hasPermission('tasks', 'delete');
    }
    
    match /members/{memberId} {
      allow read: if true;
      allow create, update: if hasPermission('team', 'edit');
      allow delete: if hasPermission('team', 'delete');
    }
    
    match /registry/{registryId} {
      allow read: if true;
      allow create, update: if hasPermission('registry', 'edit');
      allow delete: if hasPermission('registry', 'delete');
    }

    match /departments/{deptId} {
      allow read: if true;
      allow create, update: if hasPermission('team', 'edit');
      allow delete: if hasPermission('team', 'delete');
    }
    
    match /settings/{docId} {
      allow read: if true;
      allow create, update: if hasPermission('branding', 'edit');
      allow delete: if hasPermission('branding', 'delete');
    }

    // ─── Administrative Broadcasts ───────────────────────────────────
    
    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow create: if hasPermission('branding', 'edit');
      allow update: if isAuthenticated() && (
        hasPermission('branding', 'edit') || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']))
      );
      allow delete: if hasPermission('branding', 'edit');
    }
    
    match /bimReviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if hasPermission('tasks', 'edit');
    }

    // ─── Default ─────────────────────────────────────────────────────
    
    match /{path=**} {
      allow read, write: if false; // Deny all other access
    }
  }
}
