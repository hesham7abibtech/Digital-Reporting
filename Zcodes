# 1. Authorize Script Execution (MANDATORY)
# Run this once in a PowerShell window to unlock your environment
Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser

# 2. Local Environment Fix (Satisfies Cloudflare Dependencies)
$env:Path += ";C:\Program Files\Git\bin;C:\Program Files\Git\usr\bin"

# 3. Purge & Sync
Remove-Item -Recurse -Force app\.next, app\.vercel, app\out -ErrorAction SilentlyContinue
git add -A
git commit -m "feat: infrastructure and auth stabilization"
git push

# 4. Production Deployment
# If local build fails due to 'spawn bash', your code is already in GitHub 
# and will auto-deploy if your Cloudflare Pages is connected.
cd app
powershell -ExecutionPolicy Bypass -Command "npm run pages:deploy"
cd ..
