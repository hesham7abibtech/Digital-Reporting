// Rules v4.1 - Handshake Permission Fix, deployed 2026-04-24
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: check if user is approved
    function isApproved() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() &&
        exists(userPath) &&
        get(userPath).data.get('isApproved', false) == true;
    }
    
    // Helper: check if user is an admin or owner
    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() &&
        exists(userPath) &&
        (
          get(userPath).data.get('isAdmin', false) == true ||
          get(userPath).data.get('role', '') == 'ADMIN' ||
          get(userPath).data.get('role', '') == 'OWNER' ||
          get(userPath).data.get('role', '') == 'SUPER_ADMIN'
        );
    }

    // Password Reset Security Tokens (Handshake Authorization)
    match /passwordResetRequests/{oobCode} {
      // Allow public read/update for the specific token if they possess the oobCode
      // This is a "handshake" pattern where the secret code acts as the permission
      allow read: if true;
      allow update: if true;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isApproved() || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isApproved', 'access', 'email', 'role']))
      );
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Diagnostic Audit Logs
    match /diagnostics/{docId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Group Policies
    match /policies/{policyId} {
      allow read, write: if isAuthenticated() && isAdmin();
    }

    // Members / Team Listing
    match /members/{memberId} {
      allow read: if isAuthenticated() && (isApproved() || isAdmin());
      allow write: if isAuthenticated() && isAdmin();
    }

    // Project Settings Metadata
    match /settings/{docId} {
      allow read: if isAuthenticated() && (isApproved() || isAdmin());
      allow write: if isAuthenticated() && isAdmin();
    }

    match /projectMetadata/{docId} {
      allow read: if isAuthenticated() && (isApproved() || isAdmin());
      allow write: if isAuthenticated() && isAdmin();
    }

    // Tasks / Deliverables Rules
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (isAdmin() || (isApproved() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('access', {}).get('deliverablesRegistry', false)));
      allow write: if isAuthenticated() && isAdmin();
    }

    // BIM Reviews Rules
    match /bimReviews/{reviewId} {
      allow read: if isAuthenticated() && (isAdmin() || (isApproved() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('access', {}).get('bimReviews', false)));
      allow write: if isAuthenticated() && isAdmin();
    }

    // Registry / Nav items
    match /registry/{itemId} {
      allow read: if isAuthenticated() && (isApproved() || isAdmin());
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // Departments
    match /departments/{deptId} {
      allow read: if isAuthenticated() && (isApproved() || isAdmin());
      allow write: if isAuthenticated() && isAdmin();
    }

    // Tickets / Support Requests
    match /tickets/{ticketId} {
      allow read, update, delete: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }

    // Global Fallback (Admin-only catch-all)
    match /{document=**} {
      allow read, write: if isAuthenticated() && isAdmin();
    }
  }
}
