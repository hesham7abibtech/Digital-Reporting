# Header configuration for Cloudflare Pages
# Ensures HTML is never cached stale and static assets are cached aggressively

# Default: No-cache for HTML and other text files
/*
  Cache-Control: public, max-age=0, must-revalidate

# Aggressive caching for static assets
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/logos/*
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable
